      "parameters": {
        "jsCode": "const items = $('Fetch KB Index (Decay)').all();\nconst now = new Date();\nconst thirtyDays = 30 * 24 * 60 * 60 * 1000;\nconst sixtyDays = 60 * 24 * 60 * 60 * 1000;\nconst ninetyDays = 90 * 24 * 60 * 60 * 1000;\n\nconst staleItems = items.map(item => {\n  const addedAt = new Date(item.json.added_at || now);\n  const age = now - addedAt;\n  const ageDays = Math.floor(age / (24 * 60 * 60 * 1000));\n  \n  let urgency = null;\n  if (age > ninetyDays) urgency = 'critical';\n  else if (age > sixtyDays) urgency = 'high';\n  else if (age > thirtyDays) urgency = 'medium';\n  \n  return urgency ? {\n    title: item.json.title,\n    category: item.json.category,\n    ageDays,\n    urgency,\n    addedAt: item.json.added_at\n  } : null;\n}).filter(Boolean);\n\nconst msg = staleItems.length > 0 \n  ? `?? *Knowledge Decay Alert*\\n\\n${staleItems.map(i => `?? *${i.title}*\\n   Category: ${i.category}\\n   Age: ${i.ageDays} days\\n   Urgency: ${i.urgency.toUpperCase()}`).join('\\n\\n')}\\n\\n?? Please review and update these documents.`\n  : `? *Knowledge Base Health Check*\\nAll documents are up to date!`;\n\nreturn [{ json: { staleCount: staleItems.length, staleItems, telegramMsg: msg } }];"
      },
