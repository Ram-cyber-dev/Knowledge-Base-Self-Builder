      "parameters": {
        "jsCode": "const input = $input.first().json;\nlet text = \"\";\ntry { text = input.choices[0].message.content; } catch(e) {}\n\nlet digest = {};\ntry {\n  const cleaned = text.replace(/\\`\\`\\`json\\\\n?|\\\\n?\\`\\`\\`/g, '').trim();\n  digest = JSON.parse(cleaned);\n} catch(e) {\n  digest = { weekly_summary: \"Unable to generate digest\", health_score: \"N/A\" };\n}\n\nconst msg = `?? *Weekly Knowledge Base Digest*\\n\\n` +\n  `?? Health Score: *${digest.health_score || 'N/A'}/10*\\n` +\n  `?? Total Documents: ${digest.total_documents || 0}\\n` +\n  `?? Categories: ${(digest.categories_covered || []).join(', ')}\\n\\n` +\n  `?? Strongest Areas:\\n${(digest.strongest_areas || []).map(a => `. ${a}`).join('\\n')}\\n\\n` +\n  `?? Knowledge Gaps:\\n${(digest.knowledge_gaps || []).map(g => `. ${g}`).join('\\n')}\\n\\n` +\n  `?? Recommended Additions:\\n${(digest.recommended_additions || []).map(r => `. ${r}`).join('\\n')}\\n\\n` +\n  `?? Summary: ${digest.weekly_summary || ''}`;\n\nreturn [{ json: { digest, telegramMsg: msg } }];"
