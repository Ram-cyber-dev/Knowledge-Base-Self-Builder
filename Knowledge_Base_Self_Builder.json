        "url": "https://YOUR_PROJECT.supabase.co/rest/v1/rpc/search_graph",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "entity",
              "value": "={{ $fromAI('entity', 'The exact name of one entity (person, team, product, or concept) to look up relationships for, for example Priya Sharma or Engineering Team', 'string') }}"
            }
          ]
        },
        "options": {}
