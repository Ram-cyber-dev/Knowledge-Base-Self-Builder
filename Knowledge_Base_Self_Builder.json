    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nlet contradictionData = { has_contradictions: false, contradictions: [], safe_to_add: true };\n\ntry {\n  const text = input.choices[0].message.content || '';\n  const cleaned = text.replace(/```json\\n?|\\n?```/g, '').trim();\n  contradictionData = JSON.parse(cleaned);\n} catch(e) {}\n\nreturn [{\n  json: {\n    ...input,\n    contradictionCheck: contradictionData,\n    hasContradictions: contradictionData.has_contradictions || false,\n    safeToAdd: contradictionData.safe_to_add !== false\n  }\n}];"
      },
      "id": "parser-node-id-unique",
      "name": "Parse Contradiction Check",
