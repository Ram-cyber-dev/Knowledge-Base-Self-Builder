    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst contradiction = data.contradictionCheck || {};\nconst entities = data.output?.entities || data.entities || [];\nconst relationships = data.output?.relationships || data.relationships || [];\nconst summary = data.output?.summary || data.summary || '';\nconst title = data.output?.title || data.title || '';\nconst category = data.output?.category || data.category || '';\nconst tags = data.output?.tags || data.tags || [];\n\nlet score = 100;\nconst penalties = [];\n\nif (!title) { score -= 20; penalties.push('Missing title'); }\nif (!summary || summary.length < 50) { score -= 15; penalties.push('Summary too short'); }\nif (!category) { score -= 10; penalties.push('Missing category'); }\nif (tags.length === 0) { score -= 10; penalties.push('No tags'); }\nif (entities.length === 0) { score -= 15; penalties.push('No entities extracted'); }\nif (relationships.length === 0) { score -= 10; penalties.push('No relationships mapped'); }\nif (contradiction.has_contradictions) {\n  score -= 20;\n  penalties.push('Contradictions detected');\n}\n\nscore = Math.max(0, score);\n\nlet band = 'high';\nif (score < 50) band = 'low';\nelse if (score < 75) band = 'medium';\n\nconst citationChain = {\n  documentTitle: title,\n  category,\n  summary,\n  entityCount: entities.length,\n  relationshipCount: relationships.length,\n  extractedAt: new Date().toISOString(),\n  confidenceScore: score,\n  confidenceBand: band,\n  qualityPenalties: penalties\n};\n\nreturn [{ json: { ...data, confidenceScore: score, confidenceBand: band, citationChain, qualityPenalties: penalties } }];"
      },
