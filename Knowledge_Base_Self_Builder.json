        "jsCode": "const item = $input.first();\nconst data = item.json;\nconst fileName = data.name || data.fileName || '';\nconst ext = fileName.split('.').pop().toLowerCase();\n\nconst fileTypeMap = {\n  'pdf': 'pdf',\n  'docx': 'docx',\n  'doc': 'docx',\n  'txt': 'text',\n  'md': 'text',\n  'png': 'image',\n  'jpg': 'image',\n  'jpeg': 'image',\n  'mp3': 'audio',\n  'mp4': 'audio',\n  'm4a': 'audio',\n  'wav': 'audio'\n};\n\nconst fileType = fileTypeMap[ext] || 'unknown';\nconst supportedTypes = ['pdf', 'docx', 'text', 'image', 'audio'];\nconst isSupported = supportedTypes.includes(fileType);\n\nreturn [{ \n  json: { \n    ...data,\n    detectedFileType: fileType,\n    fileExtension: ext,\n    fileName: fileName,\n    isSupported,\n    processingNote: isSupported \n      ? `Processing ${ext.toUpperCase()} file via ${fileType} pipeline` \n      : `Unsupported file type: ${ext}`\n  },\n  binary: item.binary\n}];"
